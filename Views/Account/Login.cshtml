@{
    ViewData["Title"] = "Вход";
    Layout = null;
}

<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Вход — PGDSDiary</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/login.css" />
</head>
<body>

    <!-- ЛЯВА СТРАНА -->
    <div class="login-left">
        <img src="~/images/logo.png" alt="Logo" />
        <h1>PGDSDiary</h1>
        <p>Електронен дневник</p>
        <div class="login-divider"></div>
    </div>

    <!-- ДЯСНА СТРАНА -->
    <div class="login-right">
        <div class="login-box">
            <h2>Добре дошли!</h2>
            <p class="subtitle">Влезте с вашите данни за достъп</p>

            @if (ViewBag.Error != null)
            {
                <div class="error-msg">
                    <i class="fas fa-circle-exclamation"></i>
                    @ViewBag.Error
                </div>
            }

            <form method="post" action="/Account/Login" id="loginForm" novalidate>
                <label class="form-label">Потребителско име</label>
                <div class="input-wrap">
                    <i class="fas fa-user"></i>
                    <input type="text" name="username" id="username" class="form-control"
                           placeholder="Въведи потребителско име" />
                </div>
                <div id="usernameError" style="color:#e53e3e;font-size:12px;margin-top:-8px;margin-bottom:8px;display:none;">
                    <i class="fas fa-circle-exclamation"></i> Въведи потребителско име
                </div>

                <label class="form-label">Парола</label>
                <div class="input-wrap">
                    <i class="fas fa-lock"></i>
                    <input type="password" name="password" id="password" class="form-control"
                           placeholder="Въведи парола" />
                </div>
                <div id="passwordError" style="color:#e53e3e;font-size:12px;margin-top:-8px;margin-bottom:8px;display:none;">
                    <i class="fas fa-circle-exclamation"></i> Въведи парола
                </div>

                <button type="submit" class="btn-login">
                    <i class="fas fa-right-to-bracket"></i> Вход в системата
                </button>
            </form>

            <script>
                document.getElementById('loginForm').addEventListener('submit', function(e) {
                    let valid = true;
                    const username = document.getElementById('username');
                    const password = document.getElementById('password');
                    const usernameError = document.getElementById('usernameError');
                    const passwordError = document.getElementById('passwordError');

                    if (!username.value.trim()) {
                        usernameError.style.display = 'block';
                        username.style.borderColor = '#e53e3e';
                        valid = false;
                    } else {
                        usernameError.style.display = 'none';
                        username.style.borderColor = '';
                    }

                    if (!password.value.trim()) {
                        passwordError.style.display = 'block';
                        password.style.borderColor = '#e53e3e';
                        valid = false;
                    } else {
                        passwordError.style.display = 'none';
                        password.style.borderColor = '';
                    }

                    if (!valid) e.preventDefault();
                });
            </script>
        </div>
    </div>
</body>
</html>