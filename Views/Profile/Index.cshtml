@model GradingSystem.Models.ApplicationUser

@{
    ViewData["Title"] = "Моят профил";
}

<div class="page-header">
    <div>
        <h1>Моят профил</h1>
        <p>Управлявай своята информация</p>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div style="background:#e8f5ee;border:1px solid #2e7d50;color:#2e7d50;padding:12px 16px;border-radius:8px;margin-bottom:20px;display:flex;align-items:center;gap:10px;">
        <i class="fas fa-check-circle"></i> @TempData["Success"]
    </div>
}
@if (TempData["Error"] != null)
{
    <div style="background:#fee2e2;border:1px solid #e53e3e;color:#b91c1c;padding:12px 16px;border-radius:8px;margin-bottom:20px;display:flex;align-items:center;gap:10px;">
        <i class="fas fa-exclamation-circle"></i> @TempData["Error"]
    </div>
}

<div style="display:grid;grid-template-columns:280px 1fr;gap:20px;max-width:900px;margin:0 auto;">

    <!-- СНИМКА -->
    <div class="card" style="text-align:center;padding:32px 20px;">
        <div style="margin-bottom:16px;">
            @if (!string.IsNullOrEmpty(Model.ProfilePicture))
            {
                <img src="@Model.ProfilePicture" style="width:100px;height:100px;border-radius:50%;object-fit:cover;border:3px solid var(--accent);" />
            }
            else
            {
                <div style="width:100px;height:100px;border-radius:50%;background:var(--accent);color:white;font-size:36px;font-weight:800;display:flex;align-items:center;justify-content:center;margin:0 auto;border:3px solid var(--accent);">
                    @Model.FirstName?.Substring(0, 1).ToUpper()
                </div>
            }
        </div>
        <div style="font-weight:800;font-size:16px;">@Model.FirstName @Model.LastName</div>
        <div style="color:var(--text-muted);font-size:13px;margin-bottom:20px;">@Model.UserName</div>

        <form method="post" action="/Profile/UpdatePicture" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <label style="display:block;cursor:pointer;">
                <div class="btn btn-outline" style="width:100%;margin-bottom:8px;">
                    <i class="fas fa-camera"></i> Избери снимка
                </div>
                <input type="file" name="picture" accept="image/*" style="display:none;"
                       onchange="this.form.submit()" />
            </label>
        </form>
    </div>

    <!-- ДЯСНА КОЛОНА -->
    <div style="display:flex;flex-direction:column;gap:20px;">

        <!-- ИНФОРМАЦИЯ -->
        <div class="card">
            <div class="card-title">
                <i class="fas fa-user" style="color:var(--accent);"></i>
                Лична информация
            </div>
            <form method="post" action="/Profile/UpdateInfo">
                @Html.AntiForgeryToken()
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px;">
                    <div class="form-group">
                        <label class="form-label">Име</label>
                        <input type="text" name="firstName" class="form-control" value="@Model.FirstName" required />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Фамилия</label>
                        <input type="text" name="lastName" class="form-control" value="@Model.LastName" required />
                    </div>
                </div>
                <div class="form-group" style="margin-bottom:16px;">
                    <label class="form-label">Потребителско име</label>
                    <input type="text" class="form-control" value="@Model.UserName" disabled style="background:var(--bg);color:var(--text-muted);" />
                </div>
                <div class="form-group" style="margin-bottom:16px;">
                    <label class="form-label">Имейл</label>
                    <input type="text" class="form-control" value="@Model.Email" disabled style="background:var(--bg);color:var(--text-muted);" />
                </div>
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save"></i> Запази
                </button>
            </form>
        </div>

        <!-- ПАРОЛА -->
        <div class="card">
            <div class="card-title">
                <i class="fas fa-lock" style="color:#d97706;"></i>
                Смяна на парола
            </div>
            <form method="post" action="/Profile/UpdatePassword">
                @Html.AntiForgeryToken()
                <div class="form-group" style="margin-bottom:16px;">
                    <label class="form-label">Текуща парола</label>
                    <input type="password" name="currentPassword" class="form-control" required />
                </div>
                <div class="form-group" style="margin-bottom:16px;">
                    <label class="form-label">Нова парола</label>
                    <input type="password" name="newPassword" class="form-control" required />
                </div>
                <div class="form-group" style="margin-bottom:16px;">
                    <label class="form-label">Потвърди парола</label>
                    <input type="password" name="confirmPassword" class="form-control" required />
                </div>
                <button type="submit" class="btn btn-primary" style="background:#d97706;border-color:#d97706;">
                    <i class="fas fa-key"></i> Смени паролата
                </button>
            </form>
        </div>

    </div>
</div>