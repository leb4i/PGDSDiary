@model IEnumerable<GradingSystem.Models.ScheduleSlot>

@{
    ViewData["Title"] = "Разписание";

    var days = new[] { "Понеделник", "Вторник", "Сряда", "Четвъртък", "Петък" };

    // Изчисляваме датите на текущата седмица
    var today = DateTime.Today;
    int diff = (int)today.DayOfWeek - 1;
    if (diff < 0) diff = 6;
    var monday = today.AddDays(-diff);

    var maxPeriod = Model.Any() ? Model.Max(s => s.PeriodNumber) : 8;
}

<div class="page-header">
    <div>
        <h1>Разписание</h1>
        <p>Седмична програма по класове</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="fas fa-plus"></i> Добави час
    </a>
</div>

@if (!User.IsInRole("Student"))
{
<!-- ФИЛТЪР -->
<div class="card" style="margin-bottom:20px;padding:16px;">
    <form method="get" style="display:flex;gap:12px;align-items:center;flex-wrap:wrap;">
        <label class="form-label" style="margin:0;font-weight:700;">Клас:</label>
        <select name="classId" class="form-control" style="width:120px;" onchange="this.form.submit()">
            <option value="">Всички</option>
            @if (ViewBag.Classes != null)
            {
                @foreach (var c in ViewBag.Classes)
                {
                    <option value="@c.Id" selected="@(ViewBag.SelectedClass == c.Id)"> @c.Name </option>
                }
            }
        </select>
        @if (ViewBag.SelectedClass != null)
        {
            <a href="/ScheduleSlots" class="btn btn-outline">
                <i class="fas fa-times"></i> Изчисти
            </a>
        }
    </form>
</div>
}
<!-- Навигация седмица -->
<div class="week-nav">
    <button class="btn btn-outline" id="prevWeek">
        <i class="fas fa-chevron-left"></i>
    </button>
    <span class="week-label" id="weekLabel"></span>
    <button class="btn btn-outline" id="nextWeek">
        <i class="fas fa-chevron-right"></i>
    </button>
    <button class="btn btn-outline" id="todayBtn">
        <i class="fas fa-calendar-day"></i> Днес
    </button>
</div>

<!-- Таблица разписание -->
<div class="table-wrapper schedule-wrapper">
    <table class="schedule-table">
        <thead>
            <tr>
                <th class="period-col">#</th>
                @for (int d = 0; d < 5; d++)
                {
                    var date = monday.AddDays(d);
                    bool isToday = date.Date == today;
                    <th class="@(isToday ? "today-col" : "")">
                        <div class="day-name">@days[d]</div>
                        <div class="day-date" data-offset="@d">@date.ToString("dd.MM.yyyy")</div>
                    </th>
                }
            </tr>
        </thead>
        <tbody>
            @for (int period = 1; period <= maxPeriod; period++)
            {
                <tr>
                    <td class="period-num">@period</td>
                    @foreach (var day in days)
                    {
                        var slot = Model.FirstOrDefault(s => s.DayOfWeek == day && s.PeriodNumber == period);
                        if (slot != null)
                        {
                            <td class="slot-cell">
                                <div class="slot-card">
                                    <div class="slot-subject">@slot.Subject?.Name</div>
                                    <div class="slot-time">
                                        <i class="fas fa-clock"></i>
                                        @slot.StartTime.ToString("HH:mm") - @slot.EndTime.ToString("HH:mm")
                                    </div>
                                    <div class="slot-class">
                                        <i class="fas fa-chalkboard"></i>
                                        @slot.Class?.Name
                                    </div>
                                </div>
                            </td>
                        }
                        else
                        {
                            <td class="slot-empty"></td>
                        }
                    }
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- МОБИЛЕН ИЗГЛЕД (1 ден) -->
<div class="mobile-schedule" style="display:none;">
    <div class="week-nav" style="justify-content:center;">
        <button class="btn btn-outline" id="prevDay"><i class="fas fa-chevron-left"></i></button>
        <span class="week-label" id="dayLabel" style="min-width:160px;text-align:center;"></span>
        <button class="btn btn-outline" id="nextDay"><i class="fas fa-chevron-right"></i></button>
    </div>

    <div id="daySlots" style="display:flex;flex-direction:column;gap:10px;margin-top:16px;">
    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
<script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>

@section Scripts {
    <script>
        const days = ["Понеделник", "Вторник", "Сряда", "Четвъртък", "Петък"];
        let allSlots = [];
        let weekOffset = 0;
        const today = new Date();
        let currentDayIndex = today.getDay() === 0 || today.getDay() === 6 ? 0 : today.getDay() - 1;

        async function loadSlots() {
            const classId = new URLSearchParams(window.location.search).get('classId') ?? '';
            const res = await fetch(`/ScheduleSlots/GetSlots?classId=${classId}`);
            allSlots = await res.json();
            checkLayout();
        }

        function getMonday(offset) {
            const d = new Date();
            const diff = d.getDay() === 0 ? 6 : d.getDay() - 1;
            d.setDate(d.getDate() - diff + (offset * 7));
            return d;
        }

        function updateDates() {
            const monday = getMonday(weekOffset);
            const friday = new Date(monday);
            friday.setDate(monday.getDate() + 4);

            const weekLabel = document.getElementById('weekLabel');
            if (weekLabel) weekLabel.textContent =
                monday.toLocaleDateString('bg-BG', { day: '2-digit', month: '2-digit' }) +
                ' – ' +
                friday.toLocaleDateString('bg-BG', { day: '2-digit', month: '2-digit', year: 'numeric' });

            document.querySelectorAll('.day-date').forEach(el => {
                const d = parseInt(el.dataset.offset);
                const date = new Date(monday);
                date.setDate(monday.getDate() + d);
                el.textContent = date.toLocaleDateString('bg-BG', { day: '2-digit', month: '2-digit', year: 'numeric' });
            });
        }

        function renderMobileDay() {
            const dayName = days[currentDayIndex];
            const monday = getMonday(weekOffset);
            const date = new Date(monday);
            date.setDate(monday.getDate() + currentDayIndex);

            document.getElementById('dayLabel').textContent =
                dayName + ' ' + date.toLocaleDateString('bg-BG', { day: '2-digit', month: '2-digit' });

            const daySlots = allSlots
                .filter(s => s.day === dayName)
                .sort((a, b) => a.period - b.period);

            const container = document.getElementById('daySlots');
            if (daySlots.length === 0) {
                container.innerHTML = '<div style="text-align:center;padding:32px;color:var(--text-muted);">Няма часове</div>';
                return;
            }

            container.innerHTML = daySlots.map(s => `
                <div style="background:var(--accent-light);border:1px solid #b7dfc8;border-radius:10px;padding:14px 16px;display:flex;align-items:center;gap:14px;">
                    <div style="width:32px;height:32px;border-radius:8px;background:var(--accent);color:white;font-weight:800;font-size:14px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                        ${s.period}
                    </div>
                    <div style="flex:1;">
                        <div style="font-weight:800;font-size:14px;">${s.subject}</div>
                        <div style="font-size:12px;color:#5a7a68;margin-top:3px;">
                            <i class="fas fa-clock"></i> ${s.startTime} - ${s.endTime}
                            ${s.className ? `&nbsp;·&nbsp;<i class="fas fa-chalkboard"></i> ${s.className}` : ''}
                        </div>
                    </div>
                </div>
            `).join('');
        }

        function checkLayout() {
            const isMobile = document.documentElement.clientWidth <= 930;
            document.querySelector('.schedule-wrapper').style.setProperty('display', isMobile ? 'none' : '', 'important');
            document.querySelectorAll('.week-nav').forEach(el =>
                el.style.setProperty('display', isMobile ? 'none' : 'flex', 'important')
            );
            document.querySelector('.mobile-schedule').style.setProperty('display', isMobile ? 'block' : 'none', 'important');
            if (isMobile) renderMobileDay();
        }

        document.getElementById('prevWeek').onclick = () => { weekOffset--; updateDates(); };
        document.getElementById('nextWeek').onclick = () => { weekOffset++; updateDates(); };
        document.getElementById('todayBtn').onclick = () => { weekOffset = 0; updateDates(); };
        document.getElementById('prevDay').onclick = () => { currentDayIndex = (currentDayIndex - 1 + 5) % 5; renderMobileDay(); };
        document.getElementById('nextDay').onclick = () => { currentDayIndex = (currentDayIndex + 1) % 5; renderMobileDay(); };

        updateDates();
        loadSlots();
        window.addEventListener('resize', checkLayout);
    </script>
}