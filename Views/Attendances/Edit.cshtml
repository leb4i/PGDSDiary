@model GradingSystem.Models.Attendance
@{
    ViewData["Title"] = "Редактирай присъствие";
}
<div class="page-header">
    <div>
        <h1>Редактирай присъствие</h1>
    </div>
    <a asp-action="Index" class="btn btn-outline">
        <i class="fas fa-arrow-left"></i> Назад
    </a>
</div>
<div class="card" style="max-width: 560px;">
    <form asp-action="Edit">
        <input type="hidden" asp-for="Id" />
        <div class="form-group">
            <label class="form-label">Ученик</label>
            <select asp-for="StudentId" class="form-select" asp-items="ViewBag.StudentId">
                <option value="">-- Избери ученик --</option>
            </select>
        </div>
        <div class="form-group">
            <label class="form-label">Предмет</label>
            <select asp-for="SubjectId" class="form-select" asp-items="ViewBag.SubjectId">
                <option value="">-- Избери предмет --</option>
            </select>
        </div>
        <div class="form-group">
            <label class="form-label">Дата</label>
            <input asp-for="Date" class="form-control" type="date" />
        </div>
        <div class="form-group">
            <label class="form-label">Статус</label>
            <select asp-for="Status" class="form-select">
                <option value="Присъства">Присъства</option>
                <option value="Отсъства">Отсъства</option>
                <option value="Закъснение">Закъснение</option>
            </select>
        </div>
        <button type="submit" class="btn btn-primary">
            <i class="fas fa-save"></i> Запази
        </button>
    </form>
</div>